[package]
name = "rust_hello"
version = "0.1.0"
edition = "2024"

[lib]
crate-type = ["cdylib", "rlib"]

[dependencies]
eframe = "0.35"
egui = "0.35"
wasm-bindgen = "0.2"
wasm-bindgen-futures = "0.4"   # FIX
web-sys = { version = "0.3", features = ["Window", "Performance"] }
console_error_panic_hook = "0.1"
gloo-timers = { version = "0.3", features = ["futures"] }

