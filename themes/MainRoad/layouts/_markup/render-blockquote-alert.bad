{{- /* Map .AlertType to icon severity */ -}}


{{ $emojis := dict
  "caution" ":exclamation:"
  "important" ":information_source:"
  "note" ":information_source:"
  "tip" ":bulb:"
  "warning" ":information_source:"
}}

{{- $typeToSev := dict
  "note"      "note"
  "tip"       "tip"
  "important" "important"
  "caution"   "caution"
  "warning"   "warning"
-}}
{{ partial "components/alert" (dict "text" .Text "severity" (index $typeToSev .AlertType)) }}
